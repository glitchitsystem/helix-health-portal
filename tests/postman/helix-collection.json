      "name": "Auth",
      "item": [
        {
          "name": "POST Login — provider",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200\", function () {\r",
                  "    pm.expect(pm.response).to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response has accessToken string\", function () {\r",
                  "    const json = pm.response.json();\r",
                  "    pm.expect(json.data.accessToken).to.be.a('string');\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response has refreshToken string\", function () {\r",
                  "    const json = pm.response.json();\r",
                  "    pm.expect(json.data.refreshToken).to.be.a('string');\r",
                  "});\r",
                  "\r",
                  "pm.test(\"User role is provider\", function () {\r",
                  "    const json = pm.response.json();\r",
                  "    pm.expect(json).to.have.nested.property('data.user.role', 'provider');\r",
                  "});\r",
                  "\r",
                  "// Store tokens for use in later requests\r",
                  "const json = pm.response.json();\r",
                  "pm.collectionVariables.set('accessToken', json.data.accessToken);\r",
                  "pm.collectionVariables.set('refreshToken', json.data.refreshToken);\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
