    {
      "name": "Patients",
      "item": [
        {
          "name": "GET /patients — provider role",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200\", () => {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response envelope is successful\", () => {\r",
                  "    const json = pm.response.json();\r",
                  "    pm.expect(json.success).to.be.true;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"data is a non-empty array\", () => {\r",
                  "    const json = pm.response.json();\r",
                  "    pm.expect(json.data).to.be.an(\"array\").with.length.above(0);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"First patient has required fields\", () => {\r",
                  "    const patient = pm.response.json().data[0];\r",
                  "    pm.expect(patient.id).to.be.a(\"number\");\r",
                  "    pm.expect(patient.first_name).to.be.a(\"string\");\r",
                  "    pm.expect(patient.last_name).to.be.a(\"string\");\r",
                  "    pm.expect(patient.mrn).to.exist;\r",
                  "});\r",
                  "\r",
                  "// Post-test: capture first patient's ID for downstream requests\r",
                  "const firstPatient = pm.response.json().data[0];\r",
                  "if (firstPatient && firstPatient.id) {\r",
                  "    pm.collectionVariables.set(\"patientId\", firstPatient.id);\r",
                  "}\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
